.icon-picker-page {
  height: 100vh;
}

.icon-picker-page .page-content {
  padding: 24rpx 30rpx calc(50rpx + env(safe-area-inset-bottom));
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: #fff0ea;
}

.search-box input {
  flex: 1;
  min-width: 0;
  color: #312522;
  font-size: 27rpx;
}

.icon-group {
  margin-top: 34rpx;
}

.group-title {
  margin: 0 0 16rpx 4rpx;
  color: #6f5a52;
  font-size: 27rpx;
  font-weight: 900;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
}

.icon-cell {
  min-height: 154rpx;
  padding: 14rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  background: #fff0ea;
}

.icon-cell text {
  width: 100%;
  color: #8d756c;
  font-size: 18rpx;
  line-height: 1.25;
  text-align: center;
  word-break: break-all;
}

.icon-cell.selected {
  border: 3rpx solid #f0442f;
  background: #fff8f4;
}

.icon-cell.selected text {
  color: #f0442f;
}

.empty-tip {
  padding: 120rpx 0;
  color: #9a8278;
  font-size: 28rpx;
  text-align: center;
}
