<view class="page plain-page category-operation-page">
  <tl-navbar title="{{title}}" showBack="{{true}}">
  </tl-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="page-content">
      <view wx:for="{{items}}" wx:key="_id" class="operation-row card">
        <view class="operation-left">
          <view class="operation-icon">
            <tl-icon name="{{item.icon}}" size="38" color="{{type==='income'?'#25a66a':'#f0442f'}}">
            </tl-icon>
          </view>
          <view>
            <text>{{item.name}}</text>
            <text wx:if="{{item.isDefaultChild}}" class="default-tag">默认</text>
          </view>
        </view>
        <view wx:if="{{role==='owner'}}" class="operation-actions">
          <text data-item="{{item}}" bindtap="openEdit">编辑</text>
          <text wx:if="{{!item.isOther}}" data-item="{{item}}" bindtap="remove">删除</text>
        </view>
      </view>
    </view>
  </scroll-view>
  <view wx:if="{{role==='owner'||role==='member'}}" class="create-bar">
    <view bindtap="openCreate">新增分类</view>
  </view>
  <view wx:if="{{showEditor}}" class="sheet-mask" bindtap="closeEditor">
    <view class="editor-sheet" catchtap="noop">
      <view class="sheet-handle">
      </view>
      <view class="sheet-title">{{editingItem?'编辑分类':'新增分类'}}</view>
      <view class="editor-icon {{draftIcon?'chosen':''}}" bindtap="chooseIcon">
        <tl-icon wx:if="{{draftIcon}}" name="{{draftIcon}}" size="46" color="{{type==='income'?'#25a66a':'#f0442f'}}">
        </tl-icon>
        <text wx:else>+</text>
      </view>
      <view class="icon-helper">{{draftIcon?'更换图标':'选择图标（必选）'}}</view>
      <input class="name-input" value="{{draftName}}" placeholder="请输入分类名称" bindinput="bindNameInput"/>
      <view class="name-count">{{draftName.length}}/6</view>
      <view class="sheet-save" bindtap="saveEditor">保存</view>
    </view>
  </view>
</view>
