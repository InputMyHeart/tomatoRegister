.category-operation-page {
  height: 100vh;
}
.category-operation-page .page-scroll {
  height: calc(100vh - 120rpx);
}
.category-operation-page .page-content {
  padding: 28rpx 30rpx calc(210rpx + env(safe-area-inset-bottom));
}
.operation-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
}
.operation-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #312522;
  font-size: 30rpx;
  font-weight: 900;
}
.operation-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #fff0ea;
}
.default-tag {
  margin-left: 12rpx;
  color: #a58b80;
  font-size: 20rpx;
  font-weight: 700;
}
.operation-actions {
  display: flex;
  gap: 20rpx;
  color: #f0442f;
  font-size: 24rpx;
  font-weight: 800;
}
.create-bar {
  position: fixed;
  z-index: 5;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 247, 242, 0.96);
}
.create-bar view,
.sheet-save {
  height: 84rpx;
  border-radius: 999rpx;
  background: #f0442f;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 84rpx;
  text-align: center;
}
.sheet-mask {
  position: fixed;
  z-index: 20;
  inset: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(49, 37, 34, 0.35);
}
.editor-sheet {
  width: 100%;
  box-sizing: border-box;
  padding: 18rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #fff7f2;
}
.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  border-radius: 99rpx;
  background: #eadbd4;
}
.sheet-title {
  color: #312522;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
}
.editor-icon {
  width: 124rpx;
  height: 124rpx;
  margin: 34rpx auto 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed #f6b7aa;
  border-radius: 50%;
  background: #fff0ea;
  color: #f0442f;
  font-size: 58rpx;
  line-height: 1;
}
.editor-icon.chosen {
  border-style: solid;
}
.icon-helper {
  margin-bottom: 28rpx;
  color: #8d756b;
  font-size: 22rpx;
  text-align: center;
}
.name-input {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fff;
  color: #312522;
  font-size: 28rpx;
}
.name-count {
  margin: 10rpx 8rpx 26rpx;
  color: #a58b80;
  font-size: 22rpx;
  text-align: right;
}
.sheet-save {
  width: 100%;
}
.page-scroll::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}
.page-scroll {
  scrollbar-width: none;
  -ms-overflow-style: none;
}
