<view class="page plain-page category-manage-page">
  <tl-navbar title="{{ledgerName}}" showBack="{{true}}">
  </tl-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="page-content">
      <view class="category-tabs">
        <view class="tab-indicator {{pageIndex === 1 ? 'to-income' : ''}}">
        </view>
        <view class="tab {{pageIndex === 0 ? 'active' : ''}}" data-index="0" bindtap="changePage">支出分类</view>
        <view class="tab {{pageIndex === 1 ? 'active' : ''}}" data-index="1" bindtap="changePage">收入分类</view>
      </view>
      <view class="category-panel">
        <block wx:for="{{currentRows}}" wx:key="id" wx:for-item="row">
          <view class="parent-grid">
            <block wx:for="{{row.items}}" wx:key="_id" wx:for-item="item">
              <view wx:if="{{item.isManager}}" class="category-item add {{type==='income'?'income-add':''}}" data-level="parent" bindtap="openManager">
                <view class="add-icon">+</view>
                <text>{{item.name}}</text>
              </view>
              <view wx:else class="category-item {{activeParentId === item._id ? 'selected' : ''}} {{type==='income'?'income':''}}" data-id="{{item._id}}" bindtap="selectParent">
                <view class="category-icon {{type==='income'?'income':'expense'}}">
                  <tl-icon name="{{item.icon}}" size="42" color="{{type==='income'?'#25a66a':'#f0442f'}}">
                  </tl-icon>
                </view>
                <text>{{item.name}}</text>
              </view>
            </block>
          </view>
          <view wx:if="{{row.isActive}}" class="children-panel">
            <view class="children-title">{{activeParentName}}的二级分类</view>
            <view class="children-grid">
              <view wx:for="{{activeChildren}}" wx:key="_id" wx:for-item="item" class="category-item">
                <view class="category-icon {{type==='income'?'income':'expense'}}">
                  <tl-icon name="{{item.icon}}" size="38" color="{{type==='income'?'#25a66a':'#f0442f'}}">
                  </tl-icon>
                </view>
                <text>{{item.name}}</text>
              </view>
              <view wx:if="{{canCreate}}" class="category-item add {{type==='income'?'income-add':''}}" data-level="child" data-parent-id="{{activeParentId}}" bindtap="openManager">
                <view class="add-icon">+</view>
                <text>管理</text>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </scroll-view>
</view>
