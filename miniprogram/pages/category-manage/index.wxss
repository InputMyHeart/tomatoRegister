.category-manage-page {
  height: 100vh;
}
.category-manage-page .page-scroll {
  height: calc(100vh - 120rpx);
}
.category-manage-page .page-content {
  padding: 26rpx 30rpx calc(50rpx + env(safe-area-inset-bottom));
}
.page-title {
  color: #312522;
  font-size: 42rpx;
  font-weight: 900;
}
.page-subtitle {
  margin-top: 8rpx;
  color: #9a8278;
  font-size: 24rpx;
  font-weight: 700;
}
.category-tabs {
  position: relative;
  display: flex;
  margin-top: 0;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #f7eee8;
  overflow: hidden;
}
.tab {
  position: relative;
  z-index: 1;
  flex: 1;
  padding: 18rpx;
  color: #8d756b;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
}
.tab-indicator {
  position: absolute;
  z-index: 0;
  left: 8rpx;
  top: 8rpx;
  bottom: 8rpx;
  width: calc(50% - 8rpx);
  border-radius: 999rpx;
  background: #f0442f;
  box-shadow: 0 10rpx 22rpx rgba(240, 68, 47, 0.2);
  transition:
    transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1),
    background 260ms ease;
}
.tab-indicator.to-income {
  transform: translateX(100%);
  background: #25a66a;
}
.tab.active {
  color: #fff;
}
.category-panel {
  margin-top: 26rpx;
}
.category-panel {
  padding-top: 8rpx;
}
.parent-grid,
.children-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  column-gap: 14rpx;
  row-gap: 34rpx;
}
.parent-grid {
  margin-bottom: 42rpx;
}
.category-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #4b3b36;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
}
.category-item text {
  width: 100%;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.category-icon,
.add-icon {
  box-sizing: border-box;
  width: 104rpx;
  height: 104rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff0ea;
}
.category-icon.income {
  background: #edf9f2;
}
.category-item.selected .category-icon {
  box-shadow: inset 0 0 0 4rpx #f0442f;
}
.category-item.selected.income .category-icon {
  box-shadow: inset 0 0 0 4rpx #25a66a;
}
.add-icon {
  color: #f0442f;
  background: #fff8f4;
  border: 2rpx dashed #f6b7aa;
  font-size: 54rpx;
  font-weight: 400;
}
.income-add .add-icon {
  color: #25a66a;
  border-color: #9bd9b8;
}
.children-panel {
  margin: 0 0 42rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fffdfb;
  border: 1rpx solid #f3e3dc;
  box-shadow: 0 12rpx 26rpx rgba(104, 63, 47, 0.06);
}
.children-title {
  margin-bottom: 22rpx;
  color: #312522;
  font-size: 28rpx;
  font-weight: 900;
}
.page-scroll::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}
.page-scroll {
  scrollbar-width: none;
  -ms-overflow-style: none;
}
