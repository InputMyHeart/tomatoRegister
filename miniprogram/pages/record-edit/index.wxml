<view class="page plain-page edit-page">
  <tl-navbar title="{{typeLabel}}明细" showBack="{{true}}">
  </tl-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view class="page-content">
      <view class="selected-card card fade-up" bindtap="reselectCategory">
        <view class="selected-left">
          <view class="type-badge {{type}}">
            <tl-icon name="{{typeIcon}}" size="24" color="{{type === 'income' ? '#25a66a' : '#f0442f'}}">
            </tl-icon>
            <text>{{typeLabel}}</text>
          </view>
          <view class="selected-icon {{type}}">
            <tl-icon name="{{categoryIcon}}" size="34" color="{{type === 'income' ? '#25a66a' : '#f0442f'}}">
            </tl-icon>
          </view>
          <view class="selected-text">
            <view class="selected-name">{{categoryLabel}}</view>
            <view class="selected-meta">{{parentCategory}} / {{categoryName}}</view>
          </view>
        </view>
        <view class="change-link">重选</view>
      </view>
      <tl-record-form amount="{{amount}}" amount-result="{{amountResult}}" show-amount-result="{{showAmountResult}}" quick-amounts="{{quickAmounts}}" ledger-name="{{ledgerName}}" accounts="{{accounts}}" account-index="{{accountIndex}}" date="{{date}}" note="{{note}}" tag-input="{{tagInput}}" tags="{{tags}}" can-save="{{canSave}}" saving="{{saving}}" bind:amountinput="onAmountInput" bind:quickamount="setQuickAmount" bind:accountchange="onAccountChange" bind:datechange="onDateChange" bind:noteinput="onNoteInput" bind:taginput="onTagInput" bind:addtag="addTag" bind:removetag="removeTag" bind:submit="saveRecord">
      </tl-record-form>
    </view>
  </scroll-view>
</view>
