.edit-page {
  padding-bottom: 230rpx;
}

.selected-card,
.selected-left {
  display: flex;
  align-items: center;
}

.selected-card {
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding: 24rpx;
}

.selected-left {
  min-width: 0;
  gap: 14rpx;
}

.type-badge {
  height: 54rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.type-badge.expense {
  color: #f0442f;
  background: #fff0ea;
}

.type-badge.income {
  color: #25a66a;
  background: #edf9f2;
}

.selected-icon {
  width: 74rpx;
  height: 74rpx;
  border-radius: 26rpx;
  flex: 0 0 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff0ea;
}

.selected-icon.income {
  background: #edf9f2;
}

.selected-text {
  min-width: 0;
}

.selected-name {
  max-width: 360rpx;
  color: #2f2926;
  font-size: 32rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.selected-meta {
  max-width: 360rpx;
  margin-top: 6rpx;
  color: #9a8278;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.change-link {
  color: #f0442f;
  font-size: 26rpx;
  font-weight: 900;
  flex: 0 0 auto;
}
