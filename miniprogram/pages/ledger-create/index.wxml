<view class="page plain-page ledger-create-page"><custom-navbar title="创建账本" showBack="{{true}}"></custom-navbar><scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}"><view class="page-content ledger-create-content"><view class="scene {{stage === 'details' ? 'scene-detail' : ''}}"><view class="logo-glow"></view><image class="brand-logo" src="/images/brand/tomato-ledger-logo-256-transparent.png" mode="aspectFit"></image><view class="scene-title">新建一个账本</view><view class="scene-subtitle">先选一种记录方式，再给它取个好记的名字</view></view><view wx:if="{{stage === 'type'}}" class="type-stage fade-up"><view class="type-grid"><view class="type-option" wx:for="{{ledgerTypes}}" wx:key="key" data-type="{{item.key}}" bindtap="selectType" style="--accent: {{item.accent}}; --soft: {{item.soft}}; --tint: {{item.tint}};"><view class="type-icon"><ri-icon name="{{item.icon}}" size="38" color="{{item.accent}}"></ri-icon></view><view class="type-main"><view class="type-title">{{item.title}}</view><view class="type-subtitle">{{item.subtitle}}</view></view></view></view></view><view wx:else class="detail-stage fade-up"><view class="step-line"><view class="selected-pill">{{selectedType === 'shared' ? '共享账本' : '个人账本'}}</view><view class="ghost-button back-type" bindtap="backToType">重选</view></view><view class="form-panel"><view class="field-block"><view class="field-label">账本名称<text class="required-star">*</text></view><input class="ledger-input" value="{{name}}" placeholder="1-8个字符，例如：日常" bindinput="onNameInput" /></view><view class="field-block"><view class="field-label">账本备注<text class="optional-tip">（选填）</text></view><textarea class="ledger-textarea" value="{{remark}}" maxlength="80" placeholder="写一句它的用途，例如：家庭日常开销" bindinput="onRemarkInput"></textarea></view><view class="field-block"><view class="budget-switch-row"><view><view class="field-label">月预算</view><view class="budget-switch-tip">开启后可查看每月消费进度</view></view><view class="budget-toggle {{budgetEnabled ? 'is-on' : ''}}" bindtap="toggleBudget"><view class="budget-toggle-knob"></view><text>{{budgetEnabled ? '已开启' : '已关闭'}}</text></view></view><view wx:if="{{budgetEnabled}}" class="budget-input-wrap"><view class="field-label">月预算金额<text class="required-star">*</text></view><view class="budget-input-row"><text>¥</text><input class="budget-input" type="digit" value="{{monthlyBudget}}" placeholder="1 - 999999，最多两位小数" bindinput="onBudgetInput" /></view></view></view><view class="tomato-button create-button {{saving ? 'is-saving' : ''}}" bindtap="createLedger"><text>{{saving ? '创建中...' : '创建账本'}}</text></view></view></view></view></scroll-view><view wx:if="{{resultVisible}}" class="result-mask"><view class="result-sheet"><view class="result-title">创建成功</view><view class="result-summary"><view class="summary-item"><text class="summary-label">账本名称</text><text class="summary-value">{{createdLedger.name}}</text></view><view class="summary-item"><text class="summary-label">月预算</text><text class="summary-value">{{createdLedger.budgetEnabled ? '已开启' : '未开启'}}</text></view></view><view class="sheet-actions"><view class="tomato-button sheet-action" bindtap="goRecord">记一笔</view><view class="ghost-button sheet-action close-action" bindtap="closeResult">关闭</view></view></view></view></view>