<view class="page tabbar-page records-page">
  <custom-navbar title="明细"></custom-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view class="page-content">

  <view class="records-toolbar fade-up">
    <view class="ledger-chip" bindtap="switchLedger">
      <text class="ledger-name">{{ledgerName}}</text>
      <ri-icon name="arrow-down-s-line" size="28" color="#f0442f"></ri-icon>
    </view>
    <view class="month-switcher">
      <view class="month-nav" bindtap="prevMonth"><ri-icon name="arrow-left-s-line" size="38" color="#f0442f"></ri-icon></view>
      <view class="month-text">{{monthLabel}}</view>
      <view class="month-nav" bindtap="nextMonth"><ri-icon name="arrow-right-s-line" size="38" color="#f0442f"></ri-icon></view>
    </view>
  </view>

  <view class="filter-panel fade-up">
    <view class="segmented">
      <view class="seg-item {{activeType === 'all' ? 'active' : ''}}" data-type="all" bindtap="switchType">全部</view>
      <view class="seg-item {{activeType === 'expense' ? 'active' : ''}}" data-type="expense" bindtap="switchType">支出</view>
      <view class="seg-item {{activeType === 'income' ? 'active' : ''}}" data-type="income" bindtap="switchType">收入</view>
    </view>
    <view class="month-brief">
      <view><text class="brief-label">收入</text><text class="brief-income">¥{{visibleIncome}}</text></view>
      <view><text class="brief-label">支出</text><text class="brief-expense">¥{{visibleExpense}}</text></view>
      <view><text class="brief-label">共</text><text class="brief-count">{{visibleCount}} 笔</text></view>
    </view>
  </view>

  <view class="timeline fade-up" wx:if="{{hasRecords}}">
    <view class="day-section" wx:for="{{recordGroups}}" wx:key="date">
      <view class="day-sticky">
        <view>
          <view class="day-title">{{item.dateLabel}}</view>
          <view class="day-subtitle">{{item.weekday}}</view>
        </view>
        <view class="day-total">
          <text class="day-income">收 ¥{{item.income}}</text>
          <text class="day-expense">支 ¥{{item.expense}}</text>
        </view>
      </view>
      <view class="record-row" wx:for="{{item.records}}" wx:for-item="record" wx:key="id" data-id="{{record.id}}" bindtap="openRecord">
        <view class="category-mark {{record.type}}">{{record.categoryName}}</view>
        <view class="record-main">
          <view class="record-topline">
            <view class="record-title">{{record.note}}</view>
            <view class="record-amount {{record.type}}">{{record.sign}}¥{{record.amount}}</view>
          </view>
          <view class="record-meta">
            <text>{{record.time}}</text>
            <text>{{record.ownerName}}</text>
            <text>{{record.account}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-wrap card fade-up" wx:else>
    <empty-state show="{{true}}" text="暂无数据"></empty-state>
  </view>

    </view>
  </scroll-view>

  <view class="sheet-mask" wx:if="{{detailVisible}}" bindtap="closeDetail"></view>
  <view class="detail-sheet {{detailVisible ? 'show' : ''}}" wx:if="{{selectedRecord}}">
    <view class="sheet-handle"></view>
    <view class="sheet-head">
      <view>
        <view class="sheet-category">{{selectedRecord.categoryName}}</view>
        <view class="sheet-note">{{selectedRecord.note}}</view>
      </view>
      <view class="sheet-amount {{selectedRecord.type}}">{{selectedRecord.sign}}¥{{selectedRecord.amount}}</view>
    </view>
    <view class="detail-list">
      <view class="detail-row"><text>时间</text><text>{{selectedRecord.dateLabel}} {{selectedRecord.time}}</text></view>
      <view class="detail-row"><text>记录人</text><text>{{selectedRecord.ownerName}}</text></view>
      <view class="detail-row"><text>支付账户</text><text>{{selectedRecord.account}}</text></view>
      <view class="detail-row"><text>备注</text><text>{{selectedRecord.remark}}</text></view>
    </view>
    <view class="sheet-actions">
      <button class="ghost-button" bindtap="closeDetail">关闭</button>
      <button class="tomato-button" bindtap="editSelected" wx:if="{{selectedRecord.canEdit && !readonly}}">编辑</button>
      <button class="disabled-button" wx:else>仅可查看</button>
    </view>
  </view>

  <custom-tabbar active="records" readonly="{{readonly}}"></custom-tabbar>
</view>