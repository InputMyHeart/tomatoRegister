<view class="page tabbar-page records-page">
  <tl-navbar title="明细">
  </tl-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}" lower-threshold="200" bindscrolltolower="loadMore">
    <view class="page-content">
      <view class="records-toolbar fade-up">
        <view class="ledger-chip" bindtap="switchLedger">
          <text class="ledger-name">{{ledgerName}}</text>
          <tl-icon name="arrow-down-s-line" size="28" color="#f0442f">
          </tl-icon>
        </view>
        <view class="month-switcher">
          <view class="month-nav" bindtap="prevMonth">
            <tl-icon name="arrow-left-s-line" size="38" color="#f0442f">
            </tl-icon>
          </view>
          <view class="month-text">{{monthLabel}}</view>
          <view class="month-nav" bindtap="nextMonth">
            <tl-icon name="arrow-right-s-line" size="38" color="#f0442f">
            </tl-icon>
          </view>
        </view>
      </view>
      <view class="filter-panel fade-up">
        <view class="segmented">
          <view class="seg-item {{activeType === 'all' ? 'active' : ''}}" data-type="all" bindtap="switchType">全部</view>
          <view class="seg-item {{activeType === 'expense' ? 'active' : ''}}" data-type="expense" bindtap="switchType">支出</view>
          <view class="seg-item {{activeType === 'income' ? 'active' : ''}}" data-type="income" bindtap="switchType">收入</view>
        </view>
        <view class="month-brief">
          <view>
            <text class="brief-label">收入</text>
            <text class="brief-income">¥{{visibleIncome}}</text>
          </view>
          <view>
            <text class="brief-label">支出</text>
            <text class="brief-expense">¥{{visibleExpense}}</text>
          </view>
          <view>
            <text class="brief-label">共</text>
            <text class="brief-count">{{visibleCount}} 笔</text>
          </view>
        </view>
      </view>
      <view class="empty-wrap card fade-up" wx:if="{{loading}}">
        <tl-empty-state show="{{true}}" text="正在加载明细">
        </tl-empty-state>
      </view>
      <view class="empty-wrap card fade-up" wx:elif="{{isError}}">
        <tl-empty-state show="{{true}}" text="明细加载失败">
        </tl-empty-state>
        <view class="retry-button" bindtap="reload">重新加载</view>
      </view>
      <view class="timeline fade-up" wx:elif="{{hasRecords}}">
        <view class="day-section" wx:for="{{recordGroups}}" wx:key="date">
          <view class="day-sticky">
            <view>
              <view class="day-title">{{item.dateLabel}}</view>
              <view class="day-subtitle">{{item.weekday}}</view>
            </view>
            <view class="day-total">
              <text class="day-income">收 ¥{{item.income}}</text>
              <text class="day-expense">支 ¥{{item.expense}}</text>
            </view>
          </view>
          <view class="record-row" wx:for="{{item.records}}" wx:for-item="record" wx:key="id" data-id="{{record.id}}" bindtap="openRecord">
            <view class="category-mark {{record.type}}">
              <tl-icon name="{{record.type === 'income' ? 'funds-line' : 'price-tag-3-line'}}" size="32" color="{{record.type === 'income' ? '#2f9d68' : '#f0442f'}}">
              </tl-icon>
            </view>
            <view class="record-main">
              <view class="record-line">
                <view class="record-title">{{record.categoryText}}</view>
                <view class="record-amount {{record.type}}">{{record.sign}}¥{{record.amountText}}</view>
              </view>
              <view class="record-line record-subline">
                <view class="record-meta">{{record.timeText}}</view>
                <view class="record-member">
                  <image class="record-avatar" src="{{record.memberAvatar}}" mode="aspectFill">
                  </image>
                  <text class="record-member-name">{{record.memberName}}</text>
                </view>
              </view>
              <view wx:if="{{record.hasNote}}" class="record-note">{{record.noteText}}</view>
            </view>
          </view>
        </view>
        <view class="page-load-more" wx:if="{{loadingMore}}">正在加载更多…</view>
        <view class="page-load-more" wx:elif="{{!hasMore}}">没有更多记录了</view>
      </view>
      <view class="empty-wrap card fade-up" wx:else>
        <tl-empty-state show="{{true}}" text="暂无数据">
        </tl-empty-state>
      </view>
    </view>
  </scroll-view>
  <view wx:if="{{isLedgerSwitcherVisible}}" class="view-ledger-mask" bindtap="closeLedgerSwitcher">
    <view class="view-ledger-sheet" catchtap="stopLedgerSwitcherTap">
      <view class="view-ledger-handle">
      </view>
      <view class="view-ledger-title">切换账本明细</view>
      <scroll-view class="view-ledger-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view wx:for="{{ledgerOptions}}" wx:key="_id" class="view-ledger-option {{item._id === ledgerId ? 'is-viewing' : ''}}" data-id="{{item._id}}" bindtap="chooseViewLedger">
          <text>{{item.name}}</text>
          <text wx:if="{{item._id === ledgerId}}">查看中</text>
        </view>
      </scroll-view>
    </view>
  </view>
  <tl-tabbar active="records" readonly="{{readonly}}">
  </tl-tabbar>
</view>
