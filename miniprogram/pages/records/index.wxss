.records-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.ledger-chip,
.month-switcher {
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(240, 68, 47, 0.12);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 12rpx 30rpx rgba(104, 63, 47, 0.06);
}

.ledger-chip {
  max-width: 300rpx;
  height: 70rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
}

.ledger-name {
  color: #312522;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ledger-arrow {
  margin-left: 10rpx;
  color: #f0442f;
  font-size: 26rpx;
  font-weight: 900;
}

.month-switcher {
  height: 70rpx;
  border-radius: 999rpx;
  overflow: hidden;
}

.month-nav {
  width: 64rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f0442f;
  font-size: 40rpx;
  font-weight: 800;
}

.month-text {
  min-width: 160rpx;
  color: #312522;
  font-size: 27rpx;
  font-weight: 900;
  text-align: center;
}

.filter-panel {
  position: sticky;
  top: 0;
  z-index: 8;
  margin: 0 -8rpx 24rpx;
  padding: 12rpx 8rpx 16rpx;
  background: linear-gradient(180deg, rgba(255, 241, 234, 0.96), rgba(255, 247, 242, 0.88));
  backdrop-filter: blur(18rpx);
}

.segmented {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: inset 0 0 0 1rpx rgba(240, 68, 47, 0.08);
}

.seg-item {
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #987f75;
  font-size: 26rpx;
  font-weight: 800;
}

.seg-item.active {
  color: #fff;
  background: linear-gradient(135deg, #ff725f, #f0442f);
  box-shadow: 0 10rpx 22rpx rgba(240, 68, 47, 0.24);
}

.month-brief {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 0 8rpx;
}

.month-brief > view {
  display: flex;
  align-items: baseline;
}

.brief-label {
  margin-right: 8rpx;
  color: #a98f84;
  font-size: 23rpx;
  font-weight: 700;
}

.brief-income,
.brief-expense,
.brief-count {
  font-size: 26rpx;
  font-weight: 900;
}

.brief-income {
  color: #2f9d68;
}
.brief-expense {
  color: #f0442f;
}
.brief-count {
  color: #4c3a34;
}

.timeline {
  overflow: visible;
}

.day-section {
  margin-bottom: 26rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 42rpx rgba(104, 63, 47, 0.07);
  overflow: visible;
}

.day-sticky {
  position: sticky;
  top: 146rpx;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 26rpx 18rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: rgba(255, 253, 251, 0.94);
  backdrop-filter: blur(16rpx);
  border-bottom: 1rpx solid #f5e5de;
}

.day-title {
  color: #312522;
  font-size: 30rpx;
  font-weight: 900;
}

.day-subtitle {
  margin-top: 4rpx;
  color: #a98f84;
  font-size: 23rpx;
  font-weight: 700;
}

.day-total {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.day-income {
  color: #2f9d68;
}
.day-expense {
  color: #f0442f;
}

.record-row {
  display: flex;
  align-items: center;
  min-height: 118rpx;
  padding: 20rpx 26rpx;
  border-bottom: 1rpx solid #f5e9e3;
}

.record-row:last-child {
  border-bottom: none;
}

.category-mark {
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 78rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.category-mark.expense {
  color: #f0442f;
  background: #fff0ea;
}

.category-mark.income {
  color: #2f9d68;
  background: #effaf2;
}

.record-main {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
}

.record-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.record-title {
  color: #312522;
  font-size: 29rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-amount {
  flex: 0 0 auto;
  font-size: 30rpx;
  font-weight: 900;
}

.record-amount.expense,
.sheet-amount.expense {
  color: #f0442f;
}
.record-amount.income,
.sheet-amount.income {
  color: #2f9d68;
}

.record-meta {
  display: flex;
  gap: 14rpx;
  margin-top: 10rpx;
  color: #a98f84;
  font-size: 23rpx;
  font-weight: 700;
}

.empty-wrap {
  min-height: 420rpx;
  padding: 20rpx;
}

.retry-button {
  width: 240rpx;
  height: 76rpx;
  margin: 24rpx auto 0;
  border-radius: 999rpx;
  background: #f0442f;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
}

/* icon optical alignment */
.ledger-arrow,
.month-nav {
  box-sizing: border-box;
  line-height: 1;
  text-align: center;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.ledger-arrow {
  width: 28rpx;
  height: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transform: translateY(-1rpx);
}

.month-nav {
  padding-bottom: 4rpx;
}

/* remix icon replacements */
.ledger-chip tl-icon {
  margin-left: 10rpx;
  flex: 0 0 auto;
}

.month-nav tl-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
.view-ledger-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  background: rgba(49, 37, 34, 0.28);
  display: flex;
  align-items: flex-end;
}
.view-ledger-sheet {
  width: 100%;
  padding: 18rpx 30rpx calc(38rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-radius: 34rpx 34rpx 0 0;
  background: #fffdfb;
}
.view-ledger-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #ecd9d0;
}
.view-ledger-title {
  color: #312522;
  font-size: 32rpx;
  font-weight: 900;
}
.view-ledger-tip {
  margin-top: 8rpx;
  color: #9a8278;
  font-size: 22rpx;
  font-weight: 700;
}
.view-ledger-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #fff7f2;
  color: #4c3a34;
  font-size: 28rpx;
  font-weight: 800;
}
.view-ledger-option.is-viewing {
  color: #f0442f;
  background: #fff0ea;
}
.view-ledger-option text:last-child {
  font-size: 22rpx;
}
.view-ledger-list {
  max-height: 58vh;
  margin-top: 18rpx;
}
.view-ledger-list .view-ledger-option:first-child {
  margin-top: 0;
}

.page-load-more {
  padding: 28rpx 0 46rpx;
  color: #a98f84;
  font-size: 24rpx;
  text-align: center;
}
