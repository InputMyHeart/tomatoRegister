.profile-edit-page {
  padding-bottom: 80rpx;
}

.edit-card {
  padding: 10rpx 30rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(255, 241, 234, 0.92));
}

.form-group {
  min-height: 118rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #f3e6df;
}

.form-group:first-child {
  border-top: none;
}

.form-label {
  width: 132rpx;
  color: #312522;
  font-size: 29rpx;
  font-weight: 900;
}

.avatar-field {
  flex: 1;
  min-width: 0;
  height: 94rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: space-between;
  line-height: 1;
}

.avatar-field::after {
  border: none;
}

.edit-avatar {
  width: 78rpx;
  height: 78rpx;
  border-radius: 24rpx;
  background: #fff0ea;
}

.edit-avatar.default {
  transform: scale(1.08);
}

.profile-input,
.picker-value {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  display: flex;
  align-items: center;
  color: #5d4942;
  font-size: 29rpx;
  font-weight: 800;
}

.form-picker {
  flex: 1;
  min-width: 0;
}

.picker-value {
  width: 100%;
  justify-content: space-between;
}

.save-button {
  width: 100%;
  height: 92rpx;
  margin-top: 34rpx;
  border-radius: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff725f, #f0442f);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  font-size: 29rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 36rpx rgba(240, 68, 47, 0.24);
}

.save-button::after {
  border: none;
}
