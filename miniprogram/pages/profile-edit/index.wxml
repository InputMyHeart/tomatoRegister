<view class="page plain-page profile-edit-page">
  <tl-navbar title="编辑资料" showBack="{{true}}">
  </tl-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view class="page-content">
      <view class="edit-card card fade-up">
        <view class="form-group avatar-row">
          <view class="form-label">头像</view>
          <button class="avatar-field" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image class="edit-avatar {{isDefaultAvatar ? 'default' : ''}}" src="{{avatarUrl}}" mode="aspectFill">
            </image>
            <tl-icon name="arrow-right-s-line" size="32" color="#f0442f">
            </tl-icon>
          </button>
        </view>
        <view class="form-group">
          <view class="form-label">昵称</view>
          <input class="profile-input" type="nickname" value="{{nickName}}" placeholder="请输入昵称" bindinput="onNickNameInput" />
        </view>
        <view class="form-group">
          <view class="form-label">性别</view>
          <picker class="form-picker" mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
            <view class="picker-value">
              <text>{{gender}}</text>
              <tl-icon name="arrow-right-s-line" size="32" color="#f0442f">
              </tl-icon>
            </view>
          </picker>
        </view>
      </view>
      <button class="save-button fade-up" loading="{{saving}}" bindtap="saveProfile">保存资料</button>
    </view>
  </scroll-view>
</view>
