<view class="page plain-page budget-settings-page">
  <custom-navbar title="月预算" showBack="{{true}}"></custom-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view class="page-content">
      <view class="setting-card card fade-up">
        <view class="setting-head">
          <view>
            <view class="setting-title">{{ledgerName}}</view>
            <view class="setting-subtitle">设置预算，快速了解当前支出占比</view>
          </view>
          <switch checked="{{budgetEnabled}}" color="#f0442f" bindchange="onEnableChange"></switch>
        </view>
      </view>

      <view class="budget-card card fade-up {{budgetEnabled ? '' : 'is-disabled'}}">
        <view class="amount-label">月预算金额</view>
        <view class="amount-input-row">
          <text class="currency">¥</text>
          <input class="amount-input" type="number" value="{{monthlyBudget}}" disabled="{{!budgetEnabled}}" bindinput="onBudgetInput" />
        </view>
        <slider min="1" max="999999" step="1" value="{{monthlyBudget}}" disabled="{{!budgetEnabled}}" activeColor="#f0442f" backgroundColor="#ffe1d9" block-color="#f0442f" block-size="24" bindchange="onSliderChange" />
        <view class="range-line">
          <text>¥1</text>
          <text>¥999999</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="save-bar">
    <button class="tomato-button save-button {{saving ? 'disabled' : ''}}" bindtap="saveBudget">保存</button>
  </view>
</view>
