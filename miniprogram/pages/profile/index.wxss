.profile-hero-card {
  position: relative;
  overflow: hidden;
  padding: 34rpx 30rpx 28rpx;
  background: linear-gradient(145deg, #fffdfb 0%, #fff0ea 100%);
}

.profile-hero-card::after {
  content: "";
  position: absolute;
  right: -86rpx;
  top: -96rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(240, 68, 47, 0.1);
}

.identity-row,
.stats-grid,
.tool-grid {
  position: relative;
  z-index: 1;
}

.identity-row {
  min-height: 120rpx;
  display: flex;
  align-items: center;
  padding-right: 74rpx;
}

.avatar-img {
  width: 116rpx;
  height: 116rpx;
  flex: 0 0 116rpx;
  border-radius: 36rpx;
  background: #fff0ea;
  box-shadow: 0 14rpx 28rpx rgba(240, 68, 47, 0.06);
}

.identity-main {
  flex: 1;
  min-width: 0;
  padding-left: 22rpx;
}

.user-name-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.user-name {
  min-width: 0;
  color: #312522;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-tip,
.stat-label {
  color: #9d867c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.user-tip {
  margin-top: 9rpx;
}

.profile-setting {
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  z-index: 2;
  width: 58rpx;
  height: 58rpx;
  border-radius: 22rpx;
  background: rgba(255, 253, 251, 0.86);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(240, 68, 47, 0.08);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  margin-top: 26rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(240, 68, 47, 0.06);
}

.stat-item {
  position: relative;
  min-width: 0;
  padding: 2rpx 10rpx;
  text-align: center;
}

.stat-value {
  color: #312522;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-label {
  margin-top: 10rpx;
}

.profile-setting tl-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
.tools-panel,
.more-panel {
  margin-top: 26rpx;
  padding: 28rpx 24rpx 8rpx;
  background: rgba(255, 253, 252, 0.94);
}

.section-title {
  margin-bottom: 18rpx;
  color: #312522;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx 6rpx;
}

.tool-tile {
  min-width: 0;
  min-height: 128rpx;
  padding: 14rpx 4rpx 12rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.tool-tile:active,
.function-row:active {
  background: #fff4ef;
}

.tool-icon,
.function-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 24rpx;
  color: #f0442f;
  background: #fff0ea;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-title {
  width: 100%;
  margin-top: 10rpx;
  color: #312522;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.function-list {
  margin-top: 22rpx;
  border-top: 1rpx solid #f3e6df;
}

.function-row {
  min-height: 112rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3e6df;
  display: flex;
  align-items: center;
}

.function-row.last,
.function-row:last-child {
  border-bottom: none;
}

.function-main {
  flex: 1;
  min-width: 0;
  padding: 0 18rpx;
}

.function-title {
  color: #312522;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.function-tip {
  margin-top: 8rpx;
  color: #9d867c;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.function-arrow {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.danger-icon {
  background: #fff1ef;
}

.danger-title {
  color: #c55249;
}

.tool-icon tl-icon,
.function-icon tl-icon,
.function-arrow tl-icon,
.profile-setting tl-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
.logout-button {
  width: 100%;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  margin-top: 28rpx;
  border-radius: 30rpx;
  color: #f0442f;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(240, 68, 47, 0.16);
  font-size: 29rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 38rpx rgba(104, 63, 47, 0.07);
}

.logout-button::after {
  border: none;
}
