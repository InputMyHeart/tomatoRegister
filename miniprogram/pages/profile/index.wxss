.profile-page {
  padding-bottom: 150rpx;
}

.identity-card {
  display: flex;
  align-items: center;
  min-height: 156rpx;
  padding: 34rpx 30rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(255, 241, 234, 0.92));
}

.identity-logo,
.avatar-img {
  width: 112rpx;
  height: 112rpx;
  flex: 0 0 112rpx;
  border-radius: 36rpx;
}

.identity-logo {
  filter: drop-shadow(0 14rpx 22rpx rgba(240, 68, 47, 0.18));
}

.avatar-img {
  background: #fff0ea;
}

.identity-main {
  flex: 1;
  min-width: 0;
  padding: 0 24rpx;
}

.user-name {
  color: #312522;
  font-size: 38rpx;
  font-weight: 900;
}

.user-tip,
.menu-tip,
.stat-label {
  margin-top: 9rpx;
  color: #9d867c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.login-pill {
  min-width: 92rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff725f, #f0442f);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(240, 68, 47, 0.22);
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
  padding: 26rpx 18rpx;
}

.stat-item {
  min-width: 0;
  text-align: center;
}

.stat-value {
  color: #312522;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-label {
  margin-top: 10rpx;
}

.section-block {
  margin-top: 30rpx;
}

.section-title {
  margin-bottom: 16rpx;
  color: #312522;
  font-size: 32rpx;
  font-weight: 900;
}

.menu-card {
  padding: 4rpx 28rpx;
}

.menu-row {
  display: flex;
  align-items: center;
  min-height: 118rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3e6df;
}

.menu-row.last,
.menu-row:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 66rpx;
  height: 66rpx;
  flex: 0 0 66rpx;
  border-radius: 24rpx;
  color: #f0442f;
  background: #fff0ea;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-main {
  flex: 1;
  min-width: 0;
  padding: 0 18rpx;
}

.menu-title {
  color: #312522;
  font-size: 29rpx;
  font-weight: 900;
}

.menu-arrow {
  width: 36rpx;
  height: 36rpx;
  color: #f0442f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon ri-icon,
.menu-arrow ri-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-button {
  width: 100%;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  margin-top: 34rpx;
  border-radius: 30rpx;
  color: #f0442f;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(240, 68, 47, 0.16);
  font-size: 29rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 38rpx rgba(104, 63, 47, 0.07);
}

.logout-button::after {
  border: none;
}
.stats-card {
  position: relative;
  overflow: hidden;
}

.stats-card.locked .stat-item {
  filter: blur(8rpx);
  opacity: 0.72;
  transform: scale(0.98);
}

.stats-lock {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f0442f;
  font-size: 24rpx;
  font-weight: 900;
  background: rgba(255, 253, 251, 0.22);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
}
.profile-setting {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  border-radius: 24rpx;
  background: #fff0ea;
  display: flex;
  align-items: center;
  justify-content: center;
}