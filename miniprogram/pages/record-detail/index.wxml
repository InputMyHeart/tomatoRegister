<view class="page plain-page record-detail-page">
  <tl-navbar title="记录明细" showBack="{{true}}">
  </tl-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view class="page-content">
      <view wx:if="{{loading}}" class="detail-card card loading-card fade-up">
        <view class="loading-line wide">
        </view>
        <view class="loading-line">
        </view>
        <view class="loading-line short">
        </view>
      </view>
      <view wx:elif="{{isError}}" class="detail-card card empty-card fade-up">
        <tl-empty-state text="记录加载失败">
        </tl-empty-state>
        <view class="primary-action" bindtap="reload">重新加载</view>
      </view>
      <block wx:else>
        <view class="detail-hero card fade-up">
          <view class="type-mark {{record.type}}">
            <tl-icon name="{{record.typeIcon}}" size="42" color="{{record.typeIconColor}}">
            </tl-icon>
          </view>
          <view class="category-name">{{record.categoryText}}</view>
          <view class="category-path">{{record.parentCategoryText}} / {{record.typeText}}</view>
          <view class="amount {{record.type}}">{{record.sign}}¥{{record.amountText}}</view>
        </view>
        <view class="detail-card card fade-up">
          <view class="detail-row">
            <text class="detail-label">记录时间</text>
            <text class="detail-value">{{record.selectedTimeText}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">账本</text>
            <text class="detail-value">{{record.ledgerName}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">账本类型</text>
            <text class="detail-value">{{record.ledgerTypeText}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">账户</text>
            <text class="detail-value">{{record.accountText}}</text>
          </view>
        </view>
        <view class="detail-card card fade-up">
          <view class="member-row">
            <text class="detail-label">记录人</text>
            <view class="member-info">
              <image class="member-avatar" src="{{record.memberAvatar}}" mode="aspectFill">
              </image>
              <text class="member-name">{{record.memberName}}</text>
            </view>
          </view>
          <view class="note-block">
            <view class="detail-label">备注</view>
            <view class="note-text">{{record.noteText}}</view>
          </view>
          <view class="tag-list" wx:if="{{record.hasTags}}">
            <view class="tag-chip" wx:for="{{record.tags}}" wx:key="*this">#{{item}}</view>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
