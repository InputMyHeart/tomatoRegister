<view class="page ledger-detail-page">
  <custom-navbar title="账本详情" showBack="{{true}}"></custom-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" show-scrollbar="{{false}}"><view class="page-content">
    <view wx:if="{{loading}}" class="detail-card card loading-card"><view></view><view></view><view></view></view>
    <block wx:elif="{{ledger}}"><view class="detail-card card fade-up"><view class="ledger-name">{{ledger.displayName}}</view><view class="ledger-tags"><text class="ledger-tag type-tag {{ledger.typeClass}}">{{ledger.typeText}}</text><text class="ledger-tag role-tag {{ledger.roleClass}}">{{ledger.roleText}}</text></view><view class="detail-section"><view class="detail-label">账本备注</view><view class="remark {{ledger.hasRemark ? '' : 'empty'}}">{{ledger.remarkText}}</view></view><view class="detail-grid"><view><text class="detail-number">{{ledger.memberCount}}</text><text>成员</text></view><view><text class="detail-number">{{ledger.visitorCount}}</text><text>访客</text></view></view></view>
      <view wx:if="{{ledger.isOwner}}" class="actions-card card fade-up"><view class="section-title">账本操作</view><view class="action-row" bindtap="editLedger"><ri-icon name="edit-line" size="36" color="#6f625d"></ri-icon><text>编辑账本</text><text class="arrow">›</text></view><view class="action-row" bindtap="inviteLedger"><ri-icon name="group-line" size="36" color="#c85d4a"></ri-icon><text>邀请成员</text><text class="arrow">›</text></view><view class="action-row" bindtap="manageMembers"><ri-icon name="team-line" size="36" color="#58736f"></ri-icon><text>成员管理</text><text class="arrow">›</text></view><view class="action-row danger" bindtap="deleteLedger"><ri-icon name="delete-bin-line" size="36" color="#c55249"></ri-icon><text>删除账本</text><text class="arrow">›</text></view></view>
      <view wx:else class="notice-card card">你当前为{{ledger.roleText}}，可查看账本信息。</view></block>
  </view></scroll-view>
  <view wx:if="{{shareSheetVisible}}" class="sheet-mask" bindtap="closeShareSheet"><view class="share-sheet" catchtap="stopSheetTap"><view class="sheet-title">选择邀请方式</view><button wx:for="{{shareOptions}}" wx:key="mode" class="share-option" open-type="share" data-mode="{{item.mode}}" bindtap="selectShareMode"><ri-icon name="{{item.icon}}" size="34" color="#c85d4a"></ri-icon><view><view>{{item.title}}</view><text>{{item.desc}}</text></view></button></view></view>
</view>
