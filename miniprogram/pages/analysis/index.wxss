.page-head {
  margin-bottom: 24rpx;
}
.eyebrow {
  color: #e94b35;
  font-size: 26rpx;
  font-weight: 700;
}
.title {
  margin-top: 8rpx;
  color: #2f2926;
  font-size: 44rpx;
  font-weight: 900;
}

.compare-card,
.insight-card {
  padding: 32rpx;
}

.compare-card {
  margin-bottom: 24rpx;
  background: linear-gradient(145deg, #fffdfb 0%, #fff3ed 100%);
}

.compare-head,
.insight-main,
.cat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.compare-title,
.insight-title,
.section-title {
  color: #2f2926;
  font-size: 32rpx;
  font-weight: 900;
}

.compare-tip,
.muted,
.daily-label {
  margin-top: 8rpx;
  color: #978780;
  font-size: 24rpx;
}

.top-tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #e94b35;
  background: #fff0ea;
  font-size: 24rpx;
  font-weight: 800;
}

.compare-bars {
  margin-top: 30rpx;
}

.bar-row {
  display: grid;
  grid-template-columns: 70rpx 1fr 150rpx;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.bar-label {
  color: #7e6d64;
  font-size: 25rpx;
  font-weight: 800;
}

.bar-track {
  height: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f3e7df;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  animation: growBar 760ms ease both;
}

.bar-fill.income {
  background: #2f9d68;
}
.bar-fill.expense {
  background: #e94b35;
}
.bar-value {
  text-align: right;
  color: #2f2926;
  font-size: 25rpx;
  font-weight: 900;
}

.insight-text {
  margin-top: 28rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  color: #7e6d64;
  background: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
  line-height: 1.6;
}

.insight-main {
  margin-top: 28rpx;
}
.big-number {
  color: #e94b35;
  font-size: 72rpx;
  font-weight: 900;
}
.daily-box {
  min-width: 180rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff0ea;
  text-align: center;
}
.daily-value {
  margin-top: 8rpx;
  color: #e94b35;
  font-size: 34rpx;
  font-weight: 900;
}
.progress-track {
  height: 18rpx;
  margin-top: 28rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f1e7e0;
}
.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ffb45f, #e94b35);
  animation: growBar 780ms ease both;
}

.section {
  margin-top: 28rpx;
}
.category-card {
  margin-top: 16rpx;
  padding: 26rpx;
}
.cat-name {
  display: flex;
  align-items: center;
  color: #2f2926;
  font-size: 28rpx;
  font-weight: 800;
}
.cat-dot {
  width: 18rpx;
  height: 18rpx;
  margin-right: 14rpx;
  border-radius: 50%;
}
.cat-dot.tomato,
.thin-fill.tomato {
  background: #e94b35;
}
.cat-dot.amber,
.thin-fill.amber {
  background: #f3a23a;
}
.cat-dot.green,
.thin-fill.green {
  background: #45a86b;
}
.cat-dot.blue,
.thin-fill.blue {
  background: #4d8ee8;
}
.cat-amount {
  color: #6d5e57;
  font-size: 26rpx;
  font-weight: 800;
}
.thin-track {
  height: 12rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f3ece7;
}
.thin-fill {
  height: 100%;
  border-radius: 999rpx;
  animation: growBar 900ms ease both;
}

.member-card {
  margin-top: 16rpx;
  padding: 10rpx 28rpx;
}
.member-row {
  display: grid;
  grid-template-columns: 100rpx 1fr 150rpx;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 0;
}
.member-name {
  color: #2f2926;
  font-size: 28rpx;
  font-weight: 800;
}
.member-bar {
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f3ece7;
}
.member-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff9b7f, #e94b35);
  animation: growBar 840ms ease both;
}
.member-amount {
  text-align: right;
  color: #6d5e57;
  font-size: 26rpx;
  font-weight: 800;
}

@keyframes growBar {
  from {
    width: 0;
  }
}
