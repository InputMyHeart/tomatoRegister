.type-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #f7eee8;
}

.type-item {
  height: 76rpx;
  border-radius: 999rpx;
  color: #8b766d;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.type-item.active.expense {
  color: #fff;
  background: #f0442f;
  box-shadow: 0 10rpx 22rpx rgba(240, 68, 47, 0.24);
}

.type-item.active.income {
  color: #fff;
  background: #25a66a;
  box-shadow: 0 10rpx 22rpx rgba(37, 166, 106, 0.2);
}
