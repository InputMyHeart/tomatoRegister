
.type-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #f7eee8;
}

.type-item {
  height: 76rpx;
  border-radius: 999rpx;
  color: #8b766d;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.type-item.active.expense {
  color: #fff;
  background: #f0442f;
  box-shadow: 0 10rpx 22rpx rgba(240, 68, 47, 0.24);
}

.type-item.active.income {
  color: #fff;
  background: #25a66a;
  box-shadow: 0 10rpx 22rpx rgba(37, 166, 106, 0.2);
}

.group-list {
  margin-top: 24rpx;
}

.group-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.group-head,
.group-title-wrap {
  display: flex;
  align-items: center;
}

.group-head {
  justify-content: space-between;
}

.group-title-wrap {
  min-width: 0;
  gap: 18rpx;
}

.group-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff0ea;
  flex: 0 0 70rpx;
}

.group-icon.income {
  background: #edf9f2;
}

.group-name {
  color: #2f2926;
  font-size: 30rpx;
  font-weight: 900;
}

.group-count {
  margin-top: 6rpx;
  color: #9a8278;
  font-size: 23rpx;
  font-weight: 700;
}

.sub-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx 12rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #f2e9e3;
}

.sub-category {
  min-width: 0;
  height: 122rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #4b3b36;
  background: #fff8f4;
  text-align: center;
}

.sub-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff0ea;
}

.sub-icon.income {
  background: #edf9f2;
}

.sub-label {
  width: 100%;
  margin-top: 10rpx;
  color: #4b3b36;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
