<view class="page plain-page category-page">
  <tl-navbar title="{{ledgerName}}" showBack="{{true}}">
  </tl-navbar>
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view class="page-content">
      <view class="type-switch fade-up">
        <view class="type-item {{type === 'expense' ? 'active expense' : ''}}" data-type="expense" bindtap="switchType">
          <tl-icon name="price-tag-3-line" size="30" color="{{type === 'expense' ? '#ffffff' : '#f0442f'}}">
          </tl-icon>
          <text>支出</text>
        </view>
        <view class="type-item {{type === 'income' ? 'active income' : ''}}" data-type="income" bindtap="switchType">
          <tl-icon name="funds-line" size="30" color="{{type === 'income' ? '#ffffff' : '#25a66a'}}">
          </tl-icon>
          <text>收入</text>
        </view>
      </view>
      <tl-category-tree groups="{{groups}}" expanded-group-id="{{expandedGroupId}}" bind:toggle="toggleGroup" bind:select="chooseCategory">
      </tl-category-tree>
    </view>
  </scroll-view>
</view>
