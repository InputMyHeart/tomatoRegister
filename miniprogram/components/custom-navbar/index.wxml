<view class="custom-navbar">
  <view class="status-space" style="height: {{statusBarHeight}}px;"></view>
  <view class="nav-row" style="height: {{navHeight}}px;">
    <view class="nav-brand {{showBack ? 'back-only' : ''}}">
      <view wx:if="{{showBack}}" class="back-button" bindtap="handleBack">
        <ri-icon name="arrow-left-s-line" size="42" color="#f0442f"></ri-icon>
      </view>
      <image wx:else class="brand-mark" src="/images/brand/tomato-ledger-logo-256-transparent.png" mode="aspectFit"></image>
      <text wx:if="{{!showBack}}" class="brand-name">番茄记账</text>
    </view>
    <view class="nav-center">{{title}}</view>
    <view class="nav-right"></view>
  </view>
</view>