.custom-navbar {
  position: relative;
  z-index: 20;
  width: calc(100% + 56rpx);
  margin: -32rpx -28rpx 22rpx;
  padding: 0 28rpx 8rpx;
  background: transparent;
}

.nav-row,
.nav-brand {
  display: flex;
  align-items: center;
}

.nav-row {
  position: relative;
  justify-content: space-between;
}

.nav-brand,
.nav-right {
  width: 220rpx;
  min-width: 0;
}

.brand-mark,
.back-button {
  position: relative;
  width: 54rpx;
  height: 54rpx;
  flex: 0 0 54rpx;
  margin-right: 12rpx;
  border-radius: 20rpx 20rpx 24rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-mark {
  overflow: visible;
  filter: drop-shadow(0 8rpx 14rpx rgba(240, 68, 47, 0.22));
}

.back-button {
  background: rgba(255, 255, 255, 0.6);
  color: #f0442f;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 8rpx 18rpx rgba(240, 68, 47, 0.12);
}

.brand-name {
  color: #312522;
  font-size: 26rpx;
  font-weight: 900;
  white-space: nowrap;
}

.nav-center {
  position: absolute;
  left: 50%;
  max-width: 230rpx;
  transform: translateX(-50%);
  color: #312522;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* icon optical alignment */
.back-button {
  box-sizing: border-box;
  padding-bottom: 5rpx;
  text-align: center;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

/* remix icon replacements */
.back-button ri-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
