.custom-tabbar {
  flex: 0 0 auto;
  width: calc(100% + 56rpx);
  margin: 12rpx -28rpx 0;
  padding: 0 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 250, 247, 0.96);
  box-shadow: 0 -12rpx 32rpx rgba(165, 74, 47, 0.08);
}

.tabbar-shell {
  position: relative;
  min-height: 108rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
}

.tab-item {
  min-width: 0;
  height: 96rpx;
  color: #b39a90;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.tab-item:nth-child(1) { grid-column: 1; }
.tab-item:nth-child(2) { grid-column: 2; }
.tab-item:nth-child(4) { grid-column: 4; }
.tab-item:nth-child(5) { grid-column: 5; }

.tab-item.active {
  color: #f0442f;
}

.record-hub {
  grid-column: 3;
  justify-self: center;
  width: 108rpx;
  height: 108rpx;
  margin-top: -36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff8268 0%, #f0442f 100%);
  border: 8rpx solid #fffaf7;
  box-shadow: 0 18rpx 34rpx rgba(240, 68, 47, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-hub.readonly {
  background: #d8cbc4;
  box-shadow: none;
}
.tab-icon,
.hub-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  overflow: visible;
}

.tab-icon {
  width: 42rpx;
  height: 42rpx;
}

.hub-icon {
  width: 54rpx;
  height: 54rpx;
}

.tab-icon ri-icon,
.hub-icon ri-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}