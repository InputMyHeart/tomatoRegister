.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(188rpx + env(safe-area-inset-bottom));
  z-index: 80;
  height: 92rpx;
  min-width: 190rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff8268 0%, #f0442f 100%);
  color: #fff;
  box-shadow: 0 18rpx 38rpx rgba(240, 68, 47, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-plus {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  margin-right: 12rpx;
}

.fab-plus::before,
.fab-plus::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 30rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #fff;
  transform: translate(-50%, -50%);
}

.fab-plus::after {
  transform: translate(-50%, -50%) rotate(90deg);
}

.fab-text {
  font-size: 28rpx;
  font-weight: 800;
}

/* icon optical alignment */
.fab-plus {
  transform: translateY(1rpx);
}

.fab-text {
  line-height: 1;
  transform: translateY(1rpx);
}

/* remix icon replacements */
.fab-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
