.tl-category-tree__group {
  margin-top: 24rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(240, 68, 47, 0.08);
  border-radius: 34rpx;
  background: #fffdfc;
  box-shadow: 0 14rpx 34rpx rgba(165, 74, 47, 0.08);
}
.tl-category-tree__parent {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  color: #9a8278;
}
.tl-category-tree__parent-icon,
.tl-category-tree__child-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
.tl-category-tree__parent-icon {
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  border-radius: 24rpx;
  color: #f0442f;
  background: #fff0ea;
}
.tl-category-tree__parent-name {
  flex: 1;
  color: #2f2926;
  font-size: 30rpx;
  font-weight: 900;
}
.tl-category-tree__children {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx 12rpx;
  margin: 0 24rpx;
  padding: 22rpx 0 24rpx;
  border-top: 1rpx solid #f2e9e3;
}
.tl-category-tree__child {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 0;
  height: 122rpx;
  padding: 12rpx 6rpx;
  overflow: hidden;
  border-radius: 28rpx;
  color: #4b3b36;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  background: #fff8f4;
}
.tl-category-tree__child-icon {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  border-radius: 18rpx;
  color: #f0442f;
  background: #fff0ea;
}
