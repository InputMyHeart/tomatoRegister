@font-face {
  font-family: "remixicon";
  src: url("data:font/woff2;charset=utf-8;base64,") format("woff2");
  font-weight: normal;
  font-style: normal;
  font-display: block;
}

.ri {
  display: inline-flex;
  width: 1em;
  height: 1em;
  align-items: center;
  justify-content: center;
  font-family: "remixicon" !important;
  font-style: normal;
  font-weight: normal;
  line-height: 1;
  text-align: center;
  text-rendering: auto;
  -webkit-font-smoothing: antialiased;
}

.ri::before {
  display: block;
  line-height: 1;
}

