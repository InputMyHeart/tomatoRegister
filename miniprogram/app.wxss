:root {
  --tl-color-page: #fff7f2;
  --tl-color-surface: #fffdfc;
  --tl-color-primary: #f0442f;
  --tl-color-primary-soft: #fff0ea;
  --tl-color-income: #25a66a;
  --tl-color-text: #312522;
  --tl-color-text-secondary: #6f625d;
  --tl-color-border: rgba(240, 68, 47, 0.08);
  --tl-space-xs: 8rpx;
  --tl-space-sm: 16rpx;
  --tl-space-md: 24rpx;
  --tl-space-lg: 32rpx;
  --tl-radius-sm: 20rpx;
  --tl-radius-md: 34rpx;
  --tl-radius-pill: 999rpx;
  --tl-font-sm: 24rpx;
  --tl-font-md: 28rpx;
  --tl-font-lg: 32rpx;
  --tl-shadow-card: 0 14rpx 34rpx rgba(165, 74, 47, 0.08);
  --tl-z-content: 1;
  --tl-z-overlay: 100;
}
page {
  min-height: 100%;
  background: #fff7f2;
  color: #312522;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  background: initial;
  padding: 0;
  margin: 0;
  line-height: normal;
}

button::after {
  border: none;
}

/* Layout convention:
 * tl-navbar is the fixed flex header.
 * Put scrollable content in page-scroll > page-content.
 * Use tabbar-page for native tabbar pages, plain-page for non-tabbar pages.
 */
.page {
  box-sizing: border-box;
  height: 100vh;
  min-height: 100vh;
  padding: 0 28rpx;
  background:
    radial-gradient(circle at 12% -70rpx, rgba(255, 112, 88, 0.28), transparent 360rpx),
    linear-gradient(180deg, #ffe1d6 0%, #fff1ea 260rpx, #fff7f2 520rpx, #fffaf7 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tabbar-page,
.plain-page {
  padding-bottom: 0;
}

.page-scroll {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 0;
  flex: 1 1 0;
  overflow: hidden;
}

.page-content {
  width: 100%;
  min-height: 100%;
  padding-bottom: env(safe-area-inset-bottom);
}

.card {
  border-radius: 34rpx;
  background: #fffdfc;
  border: 1rpx solid rgba(240, 68, 47, 0.08);
  box-shadow: 0 14rpx 34rpx rgba(165, 74, 47, 0.08);
}

.tomato-button {
  height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #ff7d63 0%, #f0442f 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 30rpx rgba(240, 68, 47, 0.28);
}

.ghost-button {
  height: 78rpx;
  border-radius: 39rpx;
  color: #f0442f;
  background: #fff0ea;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fade-up {
  animation: fadeUp 180ms ease both;
}

.soft-pop {
  animation: softPop 220ms ease both;
}

@keyframes fadeUp {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes softPop {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
